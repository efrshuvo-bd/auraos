ENTRY(_start)

PHDRS
{
  text PT_LOAD FLAGS(5); /* PF_R|PF_X */
  data PT_LOAD FLAGS(6); /* PF_R|PF_W */
}

SECTIONS
{
  . = 0x400000;

  .text : ALIGN(16) {
    *(.text .text.*)
  } :text

  .rodata : ALIGN(16) {
    *(.rodata .rodata.*)
    *(.rodata.*)
  } :text

  .data : ALIGN(16) {
    *(.data .data.*)
  } :data

  .bss : ALIGN(16) {
    *(.bss .bss.*)
    *(COMMON)
  } :data

  /DISCARD/ : {
    *(.eh_frame*)
    *(.eh_frame_hdr*)
    *(.note*)
    *(.comment)
  }
}
